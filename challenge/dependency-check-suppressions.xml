<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppression file — CTF challenge application.

  Every CVE listed below is INTENTIONALLY PRESENT.  These libraries are pinned
  to their vulnerable versions because they ARE the challenge attack surface:

    • commons-collections 3.2.1  → gadget chain for Shiro rememberMe RCE
    • shiro-spring / shiro-web / shiro-core 1.2.4  → CVE-2016-4437 target

  DO NOT copy these suppressions into any production project.
  Full rationale: see ../SECURITY_NOTICE.md
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- ================================================================
         commons-collections 3.2.1
         All deserialization-gadget-chain CVEs are intentional.
         ================================================================ -->

    <suppress>
        <notes>Intentional CTF gadget-chain dependency. See SECURITY_NOTICE.md.</notes>
        <gav regex="true">^commons-collections:commons-collections:3\.2\.1$</gav>
        <cve>CVE-2015-6420</cve>
    </suppress>

    <suppress>
        <notes>Intentional CTF gadget-chain dependency. See SECURITY_NOTICE.md.</notes>
        <gav regex="true">^commons-collections:commons-collections:3\.2\.1$</gav>
        <cve>CVE-2015-7501</cve>
    </suppress>

    <!--
      Some scanners report the commons-collections deserialization issue under
      different identifiers (GHSA IDs, NVD duplicates, vendor advisories).
      Suppress by package coordinate so every variant is covered.
    -->
    <suppress>
        <notes>Intentional CTF gadget-chain dependency — all deserialization
        vulnerabilities in this artifact are accepted. See SECURITY_NOTICE.md.</notes>
        <gav regex="true">^commons-collections:commons-collections:3\.2\.1$</gav>
        <vulnerabilityName regex="true">(?i).*insecure deserialization.*commons.collection.*</vulnerabilityName>
    </suppress>

    <suppress>
        <notes>Intentional CTF gadget-chain dependency. See SECURITY_NOTICE.md.</notes>
        <gav regex="true">^commons-collections:commons-collections:3\.2\.1$</gav>
        <vulnerabilityName regex="true">(?i).*deserialization of untrusted data.*commons.collection.*</vulnerabilityName>
    </suppress>

